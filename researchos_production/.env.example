# ── App ──
APP_ENV=production
SECRET_KEY=change-me-use-openssl-rand-hex-32

# ── API URL (for frontend) ──
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ── Database ──
DATABASE_URL=sqlite:///./researchos.db
# Production: postgresql+psycopg://user:password@host:5432/researchos

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── Object Storage (MinIO / S3) ──
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=researchos
S3_SECRET_KEY=researchos-password
S3_BUCKET=researchos

# ── Vector DB ──
QDRANT_URL=http://localhost:6333

# ── Graph DB ──
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=researchos-password

# ── LLM Providers (optional — works offline without these) ──
LLM_PROVIDER=offline
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ── Billing ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Auth ──
JWT_SECRET=change-me-use-openssl-rand-hex-32

# ── CORS ──
CORS_ORIGINS=http://localhost:3000

# ── API Key Enforcement ──
# Set to 'true' in production to require X-API-Key on all routes
API_KEY_ENFORCEMENT=false
